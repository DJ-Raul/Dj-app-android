<?xml version="1.0" encoding="utf-8"?>
<!-- android/app/src/main/res/xml/device_filter.xml -->
<!-- Hercules DJControl Inpulse 300 USB device filter -->
<resources>
    <!-- Hercules / Guillemot Corp -->
    <usb-device vendor-id="1784" product-id="45317" />
    <!-- vendor-id="0x06F8" (1784 decimal) product-id="0xB105" (45317 decimal) -->

    <!-- Generic USB MIDI class devices as fallback -->
    <!-- class="1" subclass="3" = USB Audio MIDI Streaming -->
    <usb-device class="1" subclass="3" />
</resources>
